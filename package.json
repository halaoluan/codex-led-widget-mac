{
  "name": "codex-led-widget-mac",
  "version": "0.1.8",
  "description": "macOS liquid-glass desktop widget for showing local Codex usage quota.",
  "main": "src/main/main.js",
  "author": "Codex LED Widget macOS Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "build": "electron-builder --mac dmg zip --universal",
    "build:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --universal",
    "build:arm64": "electron-builder --mac dmg zip --arm64",
    "build:x64": "electron-builder --mac dmg zip --x64",
    "build:dir": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "notarize": "node build/notarize.js",
    "check:quota": "node scripts/check-quota.js"
  },
  "build": {
    "appId": "cn.codex.led.widget.mac",
    "productName": "Codex LED Widget",
    "directories": {
      "output": "dist"
    },
    "artifactName": "Codex-LED-Widget-${version}-mac-${arch}.${ext}",
    "afterSign": "build/notarize.js",
    "publish": [
      {
        "provider": "github",
        "owner": "halaoluan",
        "repo": "codex-led-widget-mac"
      }
    ],
    "files": [
      "src/**/*",
      "scripts/**/*",
      "package.json",
      "README.md"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal",
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal",
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "artifactName": "Codex-LED-Widget-${version}-mac-${arch}.dmg"
    }
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
